        if keys[pygame.K_DOWN] or keys[pygame.K_s]: dy=1

        result = player.move(dx,dy,grid)

        if player.dead:
            save_score(player.score)
            state = STATE_GAMEOVER

        cam_x,cam_y = get_camera(player)

        screen.fill((0,0,0))

        for y in range(WORLD_ROWS):
            for x in range(WORLD_COLS):
                rect = pygame.Rect(x*TILE_SIZE-cam_x,
                                   y*TILE_SIZE-cam_y,
                                   TILE_SIZE,TILE_SIZE)
                if rect.colliderect(screen.get_rect()):
                    tile = grid[y][x]

                    if tile in SPRITES and SPRITES[tile]:
                        screen.blit(SPRITES[tile],rect)
                    elif tile in ITEM_TYPES and ITEM_TYPES[tile]["image"]:
                        screen.blit(ITEM_TYPES[tile]["image"],rect)
