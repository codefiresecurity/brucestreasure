                        color=(60,60,60)
                        if tile==FLOOR: color=(110,110,110)
                        if tile==SPIKE: color=(200,200,200)
                        pygame.draw.rect(screen,color,rect)

        px = player.x*TILE_SIZE - cam_x
        py = player.y*TILE_SIZE - cam_y

        if PLAYER_SPRITE:
            screen.blit(PLAYER_SPRITE,(px,py))
        else:
            pygame.draw.rect(screen,(0,0,255),(px,py,TILE_SIZE,TILE_SIZE))

        draw_torch(player)
        draw_minimap(grid,player)

        score_text = font.render(f"Score: {player.score}",True,(255,255,255))
        screen.blit(score_text,(10,10))

        pygame.display.flip()

    if state == STATE_GAMEOVER:
        screen.fill((0,0,0))
        over = font.render("GAME OVER",True,(255,0,0))
        screen.blit(over,(SCREEN_WIDTH//2-100,200))

        scores = load_scores()
        y=260
        for s in scores:
            screen.blit(font.render(str(s),True,(255,255,255)),
                        (SCREEN_WIDTH//2-20,y))
            y+=30

        pygame.display.flip()
        pygame.time.wait(3000)
        state = STATE_SPLASH