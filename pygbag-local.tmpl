(function () {
    const pythonDigits = "{{cookiecutter.PYBUILD}}".replace(".", "")
    const expectedRuntime = "{{cookiecutter.cdn}}cpython" + pythonDigits + "/main.js"
    const buffer = []
    let lastLine = ""
    let heartbeatSeconds = 0
    let consoleMirrored = false

    function stamp() {
        return new Date().toLocaleTimeString([], { hour12: false })
    }

    function flushLoader() {
        const node = document.getElementById("loader-log")
        if (!node || !buffer.length) {
            return
        }

        node.textContent += buffer.join("")
        buffer.length = 0
        node.scrollTop = node.scrollHeight
    }

    function appendLoader(message) {
        const line = "[" + stamp() + "] " + message
        if (line === lastLine) {
            return
        }

        lastLine = line
        buffer.push(line + "\n")
        flushLoader()
    }

    window.loader_log = appendLoader

    function mirrorConsole(methodName) {
        const original = console[methodName]
        console[methodName] = function (...args) {
            try {
                const text = args.map((item) => {
                    if (typeof item === "string") {
                        return item
                    }
                    try {
                        return JSON.stringify(item)
                    } catch (error) {
                        return String(item)
                    }
                }).join(" ")
                appendLoader(methodName + ": " + text)
            } catch (error) {
                original.call(console, "loader mirror failed", error)
            }
            return original.apply(console, args)
        }
    }

    function mirrorStatus() {
        const statusNode = document.getElementById("status")
        if (!statusNode) {
            return
        }

        const text = (statusNode.textContent || "").trim()
        if (text) {
            appendLoader("status: " + text)
        }
    }

    if (!consoleMirrored) {
        consoleMirrored = true
        mirrorConsole("log")
        mirrorConsole("warn")
        mirrorConsole("error")
    }

    window.addEventListener("error", function (event) {
        const target = event.target
        if (target && target.src) {
            appendLoader("resource error: " + target.src)
            return
        }
        if (event.message) {
            appendLoader("error: " + event.message)
        }
    }, true)

    window.addEventListener("unhandledrejection", function (event) {
        if (event.reason) {
            appendLoader("rejection: " + event.reason)
        }
    })

    window.addEventListener("DOMContentLoaded", function () {
        appendLoader("Loader page ready.")
        appendLoader("Expecting runtime: " + expectedRuntime)
        appendLoader("Expecting archive: {{cookiecutter.archive}}.tar.gz")

        const statusNode = document.getElementById("status")
        if (statusNode) {
            const observer = new MutationObserver(mirrorStatus)
            observer.observe(statusNode, {
                childList: true,
                characterData: true,
                subtree: true
            })
        }

        window.setInterval(function () {
            heartbeatSeconds += 2
            mirrorStatus()

            if (window.python || document.querySelector("canvas")) {
                appendLoader("Runtime heartbeat: canvas/runtime detected at " + heartbeatSeconds + "s.")
                return
            }

            appendLoader("Still loading... " + heartbeatSeconds + "s elapsed.")
        }, 2000)
    })
})()

function show_infobox() {
    infobox.style.display = "block"

    const width = infobox.offsetWidth
    const height = infobox.offsetHeight
    const left = (window.innerWidth - width) / 2
    const top = (window.innerHeight - height) / 2

    infobox.style.left = left + "px"
    infobox.style.top = top + "px"
}

