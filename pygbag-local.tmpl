import sys
import asyncio
import platform
from pathlib import Path


def loader_log(message):
    try:
        platform.window.loader_log(str(message))
    except Exception:
        print(message)


async def custom_site():
    import embed

    loader_log("Python bootstrap started.")
    platform.document.body.style.background = "#09111d"
    platform.window.canvas.style.visibility = "visible"

    bundle = "{{cookiecutter.archive}}"
    appdir = Path(f"/data/data/{bundle}")
    appdir.mkdir()

    try:
        loader_log(f"Preparing archive workspace: {appdir}")

        if platform.window.location.host.find(".itch.zone") > 0:
            import zipfile

            loader_log(f"Opening {bundle}.apk")
            async with platform.fopen(f"{bundle}.apk", "rb") as archive:
                loader_log("Extracting APK archive...")
                with zipfile.ZipFile(archive) as zip_ref:
                    zip_ref.extractall(appdir.as_posix())
        else:
            import tarfile

            loader_log(f"Opening {bundle}.tar.gz")
            async with platform.fopen(f"{bundle}.tar.gz", "rb") as archive:
                loader_log("Extracting tar archive...")
                tar = tarfile.open(fileobj=archive, mode="r:gz")
                tar.extractall(path=appdir.as_posix(), filter="tar")
                tar.close()

        loader_log("Archive extracted. Preparing runtime...")
        platform.run_main(PyConfig, loaderhome=appdir / "assets", loadermain=None)

        while embed.counter() < 0:
            await asyncio.sleep(.1)

        main = appdir / "assets" / "main.py"
        loader_log(f"Resolved entrypoint: {main}")

        if not platform.window.MM.UME:
            __import__(__name__).__file__ = main
            msg = "Ready to start. Click or tap the page to enable audio."
            platform.window.infobox.innerText = msg
            loader_log(msg)

            while not platform.window.MM.UME:
                await asyncio.sleep(.1)

        loader_log("Starting async runtime...")
        await TopLevel_async_handler.start_toplevel(platform.shell, console=window.python.config.debug)

        __import__(__name__).__file__ = main

        def ui_callback(pkg):
            notice = f"installing {pkg}"
            platform.window.infobox.innerText = notice
            loader_log(notice)

        loader_log("Launching main.py")
        await shell.source(main, callback=ui_callback)

        platform.window.infobox.style.display = "none"
        platform.window.config.gui_divider = 1
        platform.window.window_resize()
        platform.window.transfer.hidden = true
        loader_log("Main game script loaded.")
        print("pygbag-local.tmpl: done")
        shell.interactive()

    except Exception as exc:
        loader_log(f"Bootstrap failed: {exc}")
        raise


asyncio.run(custom_site())


